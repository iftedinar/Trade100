// ═══════════════════════════════════════════════════════════════
// LOAD NEWS — with Finnhub + AI sentiment
// ═══════════════════════════════════════════════════════════════
let currentNewsArticles = [];
let currentNewsFilter   = 'all';

async function loadNews(ticker, force=false){
  const el=document.getElementById('newsContainer');
  if(!el) return;

  if(!finnhubKey){
    el.innerHTML=`
      <div class="news-setup">
        <h3>Connect Live News 📰</h3>
        <p>Click the ⚙ button in the top-right corner and enter your free <strong>Finnhub API key</strong> to see real headlines for ${UNIVERSE.find(s=>s.ticker===ticker)?.name||ticker}.</p>
        <p style="margin-top:8px">Get your free key at <a href="https://finnhub.io/register" target="_blank" class="api-link">finnhub.io/register</a> — no credit card needed.</p>
        <button class="btn-primary" style="margin-top:16px;max-width:200px" onclick="openModal()">Set Up Now →</button>
        <div style="margin-top:20px;border-top:1px solid var(--border);padding-top:16px">
          <div style="font-size:12px;color:var(--text-muted);margin-bottom:10px">Sample headlines (illustrative):</div>
          ${renderSampleNews(ticker)}
        </div>
      </div>`;
    return;
  }

  if(!force && NEWS_CACHE[ticker] && Date.now()-NEWS_CACHE[ticker].ts < NEWS_TTL){
    currentNewsArticles=NEWS_CACHE[ticker].articles;
    renderNewsArticles();
    return;
  }

  el.innerHTML=`<div class="chart-loading"><div class="dot-pulse"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div> Fetching live news…</div>`;

  let articles=await fetchFinnhubNews(ticker);
  if(!articles||!articles.length){
    el.innerHTML=`<div style="padding:24px;color:var(--text-muted);font-size:13px;text-align:center">No recent news found for ${ticker}. Try a different stock or check your API key.</div>`;
    return;
  }

  // Score with AI if Claude API available
  el.innerHTML=`<div class="chart-loading"><div class="dot-pulse"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div> Scoring sentiment…</div>`;
  articles=await scoreSentiment(articles);

  // Cache with sentiment
  NEWS_CACHE[ticker]={articles,ts:Date.now()};
  currentNewsArticles=articles;
  renderNewsArticles();
}

function renderNewsArticles(){
  const el=document.getElementById('newsContainer');
  const countEl=document.getElementById('newsCount');
  if(!el) return;
  const filtered=currentNewsFilter==='all'?currentNewsArticles:currentNewsArticles.filter(a=>a.sentiment===currentNewsFilter);
  if(countEl) countEl.textContent=`${filtered.length} article${filtered.length!==1?'s':''}`;
  if(!filtered.length){
    el.innerHTML=`<div style="padding:24px;text-align:center;color:var(--text-muted);font-size:13px">No ${currentNewsFilter} articles found.</div>`;
    return;
  }
  el.innerHTML=filtered.map(a=>{
    const borderCls=a.sentiment==='pos'?'pos-border':a.sentiment==='neg'?'neg-border':'neu-border';
    const sentLabel=a.sentiment==='pos'?'Positive':a.sentiment==='neg'?'Negative':'Neutral';
    const timeStr=a.time?timeAgo(a.time*1000):'';
    return`<a class="news-item ${borderCls}" href="${a.url||'#'}" target="_blank" rel="noopener noreferrer">
      <div class="news-body">
        <div class="news-meta">
          <span class="news-src">${a.source}</span>
          ${timeStr?`<span class="news-time">${timeStr}</span>`:''}
        </div>
        <div class="news-head">${a.headline}</div>
        ${a.summary?`<div class="news-desc">${a.summary}</div>`:''}
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;flex-shrink:0">
        <span class="news-sent ${a.sentiment}">${sentLabel}</span>
        ${a.image?`<img class="news-image" src="${a.image}" alt="" onerror="this.style.display='none'" loading="lazy">`:''}
      </div>
    </a>`;
  }).join('');
}

function filterNews(type, btn){
  currentNewsFilter=type;
  document.querySelectorAll('.news-filter-btn').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  renderNewsArticles();
}

function renderSampleNews(ticker){
  const name=UNIVERSE.find(s=>s.ticker===ticker)?.name||ticker;
  const samples=[
    {src:'Reuters',head:`${name} reports strong quarterly results, beating analyst estimates`,sent:'pos'},
    {src:'Bloomberg',head:`Sector headwinds could pressure ${name} margins in coming quarters`,sent:'neg'},
    {src:'CNBC',head:`Institutional investors increase positions in ${name} ahead of earnings`,sent:'pos'},
    {src:'WSJ',head:`Market volatility creates uncertainty for ${name} near-term outlook`,sent:'neu'},
  ];
  return samples.map(a=>`
    <div class="news-item ${a.sent==='pos'?'pos-border':a.sent==='neg'?'neg-border':'neu-border'}" style="pointer-events:none;opacity:.8">
      <div class="news-body">
        <div class="news-meta"><span class="news-src">${a.src}</span></div>
        <div class="news-head">${a.head}</div>
      </div>
      <span class="news-sent ${a.sent}">${a.sent==='pos'?'Positive':a.sent==='neg'?'Negative':'Neutral'}</span>
    </div>`).join('');
}

function timeAgo(ts){
  const s=Math.floor((Date.now()-ts)/1000);
  if(s<3600) return Math.floor(s/60)+'m ago';
  if(s<86400) return Math.floor(s/3600)+'h ago';
  return Math.floor(s/86400)+'d ago';
}

// ═══════════════════════════════════════════════════════════════
// CHART
// ═══════════════════════════════════════════════════════════════
async function loadChart(ticker, range, btn){
  document.querySelectorAll('.period-btn').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  const container=document.getElementById('chartContainer');
  const statusEl=document.getElementById('chartStatus');
  if(!container) return;
  if(statusEl) statusEl.innerHTML=`<span style="display:flex;align-items:center;gap:5px"><span class="dot-pulse"><span class="dot" style="width:5px;height:5px"></span></span>Loading…</span>`;
  let pairs=await getChartData(ticker,range);
  if(!pairs){
    const q=allQuotes[ticker]?.data;
    pairs=fakeSeries(q?.price??100,range);
    if(statusEl) statusEl.textContent='Estimated data';
  } else {
    if(statusEl) statusEl.textContent=`${pairs.length} data points · Yahoo Finance`;
  }
  container.innerHTML=`<canvas id="priceChart"></canvas>`;
  drawCanvas(pairs,ticker);
}

function fakeSeries(cur,range){
  const nMap={'1M':30,'6M':180,'1Y':52,'MAX':60};
  const stepMap={'1M':86400,'6M':86400,'1Y':604800,'MAX':2592000};
  const n=nMap[range]||30;
  const step=stepMap[range]||86400;
  const now=Date.now()/1000; let p=cur*(1-Math.random()*.2); const out=[];
  for(let i=0;i<n;i++){p+=(Math.random()-.47)*p*.02;out.push({t:now-(n-i)*step,v:Math.max(p,1)});}
  out.push({t:now,v:cur}); return out;
}

function drawCanvas(pairs,ticker){
  const cv=document.getElementById('priceChart'); if(!cv) return;
  const W=cv.offsetWidth||800,H=220;
  cv.width=W*devicePixelRatio; cv.height=H*devicePixelRatio;
  cv.style.width=W+'px'; cv.style.height=H+'px';
  const ctx=cv.getContext('2d'); ctx.scale(devicePixelRatio,devicePixelRatio);
  const prices=pairs.map(p=>p.v);
  const min=Math.min(...prices)*.995, max=Math.max(...prices)*1.005;
  const pad={t:20,r:16,b:30,l:64};
  const cW=W-pad.l-pad.r, cH=H-pad.t-pad.b;
  const x=i=>pad.l+(i/(pairs.length-1))*cW;
  const y=v=>pad.t+(1-(v-min)/(max-min))*cH;
  ctx.clearRect(0,0,W,H);
  // Grid
  ctx.strokeStyle='#232735'; ctx.lineWidth=1;
  for(let i=0;i<=4;i++){
    const yv=pad.t+(i/4)*cH;
    ctx.beginPath(); ctx.moveTo(pad.l,yv); ctx.lineTo(pad.l+cW,yv); ctx.stroke();
    const val=max-(i/4)*(max-min);
    ctx.fillStyle='#4a5064'; ctx.font=`10px 'JetBrains Mono',monospace`; ctx.textAlign='right';
    ctx.fillText('$'+(val>=1000?val.toLocaleString('en-US',{maximumFractionDigits:0}):val.toFixed(2)),pad.l-5,yv+4);
  }
  // X labels
  const lc=Math.min(5,pairs.length); const ls=Math.floor(pairs.length/lc);
  ctx.fillStyle='#4a5064'; ctx.font=`10px 'DM Sans',sans-serif`; ctx.textAlign='center';
  for(let i=0;i<pairs.length;i+=ls){
    const d=new Date(pairs[i].t*1000);
    ctx.fillText(d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:i>pairs.length*0.7?'2-digit':undefined}),x(i),H-6);
  }
  // Color based on direction
  const upChart=prices[prices.length-1]>=prices[0];
  const lc2=upChart?'#34d399':'#f87171';
  const gt=upChart?'rgba(52,211,153,0.22)':'rgba(248,113,113,0.22)';
  // Fill
  const grad=ctx.createLinearGradient(0,pad.t,0,pad.t+cH);
  grad.addColorStop(0,gt); grad.addColorStop(1,'rgba(0,0,0,0)');
  ctx.beginPath();
  ctx.moveTo(x(0),y(prices[0]));
  prices.forEach((v,i)=>{if(i>0)ctx.lineTo(x(i),y(v));});
  ctx.lineTo(x(prices.length-1),pad.t+cH); ctx.lineTo(x(0),pad.t+cH);
  ctx.closePath(); ctx.fillStyle=grad; ctx.fill();
  // Line
  ctx.beginPath(); ctx.strokeStyle=lc2; ctx.lineWidth=1.8; ctx.lineJoin='round';
  prices.forEach((v,i)=>i===0?ctx.moveTo(x(0),y(v)):ctx.lineTo(x(i),y(v)));
  ctx.stroke();
  // End dot
  const ex=x(prices.length-1),ey=y(prices[prices.length-1]);
  ctx.beginPath(); ctx.arc(ex,ey,4,0,Math.PI*2); ctx.fillStyle=lc2; ctx.fill();
  ctx.beginPath(); ctx.arc(ex,ey,7,0,Math.PI*2); ctx.strokeStyle=lc2+'66'; ctx.lineWidth=2; ctx.stroke();
}

// ═══════════════════════════════════════════════════════════════
// METRICS + COMPARE + STRENGTH
// ═══════════════════════════════════════════════════════════════
const TIPS={
  'P/E Ratio':  'How much investors pay per $1 of profit. Lower often means cheaper.',
  'EPS':        'Earnings Per Share — company profit ÷ total shares. Higher = more profitable.',
  'Market Cap': 'Total value of all shares combined — the "size" of the company.',
  'Volume':     'Shares traded today. High volume = lots of activity.',
  'Day Range':  'The lowest and highest price the stock hit today.',
  '52W Range':  'Lowest and highest price over the past 12 months.',
  'Dividend':   'Cash paid to shareholders per year as a % of the stock price.',
  'Beta':       'Volatility vs. the market. >1 means more volatile than average.',
};
function mkTip(label){
  const t=TIPS[label]||'';
  return`<div class="tip-wrap">${label}${t?`<div class="tip-icon">i</div><div class="tip-box">${t}</div>`:''}</div>`;
}
function buildMetrics(d,isBeg){
  const items=[
    {l:'P/E Ratio',  v:d.pe??'—',  s:'Valuation'},
    {l:'EPS',        v:d.eps!=='—'?'$'+d.eps:'—', s:'Earnings/Share'},
    {l:'Market Cap', v:d.cap,       s:'Company Size'},
    {l:'Volume',     v:d.vol,       s:'Today'},
    {l:'Day Range',  v:d.high!=='—'?`$${d.low}–$${d.high}`:'—', s:'Low → High'},
    {l:'52W Range',  v:d.wkHigh!=='—'?`$${d.wkLow}–$${d.wkHigh}`:'—', s:'Year Range'},
    {l:'Dividend',   v:d.div,       s:'Annual Yield'},
    {l:'Beta',       v:d.beta,      s:'Volatility vs Mkt'},
  ];
  const show=isBeg?items.slice(0,5):items;
  return show.map(m=>`
    <div class="metric-card">
      <div class="metric-label">${mkTip(m.l)}</div>
      <div class="metric-value">${m.v}</div>
      <div class="metric-sub">${m.s}</div>
      ${isBeg&&TIPS[m.l]?`<div class="metric-explain">${TIPS[m.l]}</div>`:''}
    </div>`).join('');
}
function buildStrengthMeter(d){
  const pe=typeof d.pe==='number'?d.pe:50;
  const sc={
    'Momentum':  d.change>=0?Math.min(50+d.change*5,90):Math.max(50+d.change*5,10),
    'Value':     pe<15?85:pe<25?65:pe<40?45:25,
    'Stability': d.beta!=='—'?Math.max(95-d.beta*25,10):50,
    'Dividend':  d.div!=='—'&&d.div!=='0%'?70:20,
    'Size':      d.cap&&d.cap.includes('T')?90:d.cap&&d.cap.includes('B')?60:40,
  };
  const clr={Momentum:'#4f8ef7',Value:'#34d399',Stability:'#a78bfa',Dividend:'#f87171',Size:'#fbbf24'};
  return`<div class="ai-block" style="margin-top:14px">
    <div class="ai-header"><div class="ai-badge">Score</div><div class="ai-title">Snapshot</div></div>
    <div class="strength-row">${Object.entries(sc).map(([k,v])=>`
      <div class="strength-item">
        <div class="strength-label">${k}</div>
        <div class="str-bg"><div class="str-fill" style="width:${v.toFixed(0)}%;background:${clr[k]}"></div></div>
        <div class="str-score">${v.toFixed(0)}</div>
      </div>`).join('')}</div>
    <div style="font-size:11px;color:var(--text-dim);margin-top:9px">Illustrative scores. Always do your own research.</div>
  </div>`;
}
function buildCompareTable(d,info,peers){
  const all=[{name:info.name,ticker:info.ticker,...d},...peers];
  return`<div class="compare-wrap">
    <table class="compare-table">
      <thead><tr><th>Company</th><th>Price</th><th>Change</th><th>P/E</th><th>Cap</th><th>Volume</th><th>Div</th></tr></thead>
      <tbody>${all.map((c,i)=>{const up=(c.change??0)>=0;return`
        <tr class="${i===0?'hl':''}">
          <td><div>${c.name||c.ticker}</div><div style="font-size:11px;color:var(--text-muted)">${c.ticker||''}</div></td>
          <td class="mono">$${typeof c.price==='number'?fmtPrice(c.price):c.price}</td>
          <td class="mono ${up?'up':'dn'}">${up?'+':''}${(c.change??0).toFixed(2)}%</td>
          <td class="mono">${c.pe??'—'}</td>
          <td class="mono">${c.cap??'—'}</td>
          <td class="mono">${c.vol??'—'}</td>
          <td class="mono">${c.div??'—'}</td>
        </tr>`;}).join('')}</tbody>
    </table></div>`;
}

// ═══════════════════════════════════════════════════════════════
// AI EXPERT ANALYSIS
// ═══════════════════════════════════════════════════════════════
async function fetchAIAnalysis(ticker,d,info){
  const el=document.getElementById('aiContent'); if(!el) return;
  try {
    const r=await fetch('/api/claude',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514', max_tokens:1000,
        messages:[{role:'user',content:`Write a concise 4-5 sentence investment research summary for ${info.name} (${ticker}).
Sector: ${info.sector}. Industry: ${info.industry}. Price: $${d.price}. Today: ${d.change>=0?'+':''}${d.change}%. P/E: ${d.pe}. Market cap: ${d.cap}. 52W: $${d.wkLow}–$${d.wkHigh}. Beta: ${d.beta}.
Mention: (1) what the company does, (2) one key strength, (3) one notable risk, (4) whether valuation looks stretched or reasonable.
Tone: professional but readable. No disclaimers.`}]
      })
    });
    const data=await r.json();
    const text=data.content?.map(c=>c.text||'').join('')||'Analysis unavailable.';
    if(el) el.innerHTML=`<div class="ai-text fade-in">${text}</div>`;
  } catch(_){
    if(el) el.innerHTML=`<div class="ai-text" style="color:var(--text-muted)">AI analysis requires API access. The Anthropic API key must be configured server-side for production use.</div>`;
  }
}


// ═══════════════════════════════════════════════════════════════
// FUNDAMENTALS — Finnhub /stock/metric + /stock/earnings
// ═══════════════════════════════════════════════════════════════
const FUND_CACHE = {};

async function loadFundamentals(ticker) {
  const box = document.getElementById('fundContainer');
  if (!box) return;
  if (!finnhubKey) {
    box.innerHTML = `<div style="background:var(--card);border:1px solid rgba(79,142,247,.2);border-radius:12px;padding:28px;text-align:center">
      <div style="font-family:'DM Serif Display',serif;font-size:18px;margin-bottom:8px">Unlock Fundamentals 📊</div>
      <p style="color:var(--text-muted);font-size:13px;line-height:1.6">Add your free <strong>Finnhub API key</strong> to see real revenue, margins, earnings history, and valuation ratios.<br>
      <a href="https://finnhub.io/register" target="_blank" style="color:var(--accent)">finnhub.io/register</a> — no credit card.</p>
      <button onclick="openModal()" style="margin-top:14px;padding:9px 20px;border-radius:8px;background:var(--accent);color:#fff;border:none;cursor:pointer;font-size:13px;font-weight:600">Set Up Now →</button>
    </div>`;
    return;
  }
  const cached = FUND_CACHE[ticker];
  if (cached && Date.now() - cached.ts < 1800000) { renderFund(ticker, cached); return; }
  box.innerHTML = `<div style="display:flex;align-items:center;gap:10px;color:var(--text-muted);font-size:13px;padding:32px 0"><div class="dot-pulse"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>Loading from Finnhub…</div>`;
  try {
    const [mr, er] = await Promise.allSettled([
      fetchWithTimeout(`/api/finnhub?type=metric&ticker=${ticker}`, 6000).then(r => r.ok ? r.json() : null),
      fetchWithTimeout(`/api/finnhub?type=earnings&ticker=${ticker}`, 6000).then(r => r.ok ? r.json() : null),
    ]);
    const entry = { metric: mr.value, earnings: er.value, ts: Date.now() };
    FUND_CACHE[ticker] = entry;
    renderFund(ticker, entry);
  } catch(_) {
    box.innerHTML = `<div style="padding:32px;text-align:center;color:var(--text-muted);font-size:13px">Could not load fundamentals. Check your API key or try again.</div>`;
  }
}

function fpct(v, d) { d = d || 1; return v != null ? v.toFixed(d) + '%' : '—'; }
function fmult(v)   { return v != null ? v.toFixed(1) + 'x' : '—'; }
function fnum(v, d) { d = d || 2; return v != null ? v.toFixed(d) : '—'; }
function gcls(v, hi){ if (v == null) return 'fneu'; return hi !== false ? (v >= 0 ? 'fgood' : 'fbad') : (v <= 0 ? 'fgood' : 'fbad'); }

function renderFund(ticker, data) {
  const box = document.getElementById('fundContainer');
  if (!box) return;
  const isBeg = currentMode === 'beginner';
  const info  = UNIVERSE.find(s => s.ticker === ticker) || {};
  const isETF = info.sector === 'ETF' || info.sector === 'Crypto';
  if (!data.metric?.metric) {
    box.innerHTML = `<div style="padding:32px;text-align:center;color:var(--text-muted);font-size:13px">Fundamental data not available for ${ticker}. This may be an ETF or crypto asset.</div>`;
    return;
  }
  const m = data.metric.metric;
  const val = [
    {l:'P/E (TTM)',   v:fmult(m.peBasicExclExtraTTM),  s:'Price to Earnings'},
    {l:'P/S (TTM)',   v:fmult(m.psTTM),                 s:'Price to Sales'},
    {l:'P/B',         v:fmult(m.pbQuarterly),            s:'Price to Book'},
    {l:'EV/EBITDA',   v:fmult(m.evEbitdaTTM),            s:'Enterprise Value'},
    {l:'52W High',    v:m['52WeekHigh'] ? '$'+m['52WeekHigh'].toFixed(2) : '—', s:'Year High'},
    {l:'52W Low',     v:m['52WeekLow']  ? '$'+m['52WeekLow'].toFixed(2)  : '—', s:'Year Low'},
  ];
  const prof = [
    {l:'Gross Margin', v:fpct(m.grossMarginTTM),        s:'After cost of goods',   c:gcls(m.grossMarginTTM)},
    {l:'Op. Margin',   v:fpct(m.operatingMarginTTM),    s:'After operating costs', c:gcls(m.operatingMarginTTM)},
    {l:'Net Margin',   v:fpct(m.netProfitMarginTTM),    s:'Bottom line %',         c:gcls(m.netProfitMarginTTM)},
    {l:'ROE',          v:fpct(m.roeTTM),                s:'Return on Equity',      c:gcls(m.roeTTM)},
    {l:'ROA',          v:fpct(m.roaTTM),                s:'Return on Assets',      c:gcls(m.roaTTM)},
    {l:'ROIC',         v:fpct(m.roicTTM),               s:'Return on Inv. Capital',c:gcls(m.roicTTM)},
  ];
  const grw = [
    {l:'Rev Growth YoY', v:fpct(m.revenueGrowthTTMYoy), s:'Year-over-year', c:gcls(m.revenueGrowthTTMYoy)},
    {l:'EPS Growth YoY', v:fpct(m.epsGrowthTTMYoy),     s:'Year-over-year', c:gcls(m.epsGrowthTTMYoy)},
    {l:'EPS Growth 5Y',  v:fpct(m.epsGrowth5Y),         s:'5-year CAGR',    c:gcls(m.epsGrowth5Y)},
    {l:'Rev Growth 5Y',  v:fpct(m.revenueGrowth5Y),     s:'5-year CAGR',    c:gcls(m.revenueGrowth5Y)},
  ];
  const hlt = [
    {l:'Current Ratio', v:fnum(m.currentRatioQuarterly),  s:'Liquidity (>1 good)', c:m.currentRatioQuarterly>=1?'fgood':'fbad'},
    {l:'Debt/Equity',   v:fnum(m.totalDebt_totalEquityQuarterly), s:'Leverage', c:m.totalDebt_totalEquityQuarterly<=1?'fgood':m.totalDebt_totalEquityQuarterly<=2?'fneu':'fbad'},
    {l:'Quick Ratio',   v:fnum(m.quickRatioQuarterly),    s:'Liquid assets/debts', c:m.quickRatioQuarterly>=1?'fgood':'fbad'},
    {l:'Div Yield TTM', v:fpct(m.dividendYieldIndicatedAnnual), s:'Annual income %', c:'fneu'},
    {l:'Payout Ratio',  v:fpct(m.payoutRatioTTM),         s:'Div as % of earnings',c:'fneu'},
    {l:'Beta',          v:fnum(m.beta, 2),                s:'vs Market',           c:'fneu'},
  ];
  const cds = arr => arr.map(c => `<div class="fcard"><div class="fl">${c.l}</div><div class="fv ${c.c||'fneu'}">${c.v}</div><div class="fsub">${c.s}</div></div>`).join('');
  const bn = isBeg ? `<div style="background:rgba(79,142,247,.06);border:1px solid rgba(79,142,247,.15);border-radius:8px;padding:11px 14px;margin-bottom:18px;font-size:12px;color:#9bb4e8;line-height:1.6">
    📊 <strong>Reading this:</strong> Green = generally good, Red = worth watching. This shows how profitable ${info.name||ticker} is, how fast it's growing, and whether it has too much debt.</div>` : '';
  const earArr = Array.isArray(data.earnings) ? data.earnings.slice(0,6) : [];
  let earHtml = '';
  if (earArr.length) {
    earHtml = `<div class="fsec"><div class="fstitle">Earnings History (EPS per quarter)</div>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:18px">
        ${earArr.map(e => {
          const act = e.actual ?? e.eps, est = e.estimate;
          const beat = act!=null&&est!=null ? (act>est*1.01?'beat':act<est*0.99?'miss':'inline') : '';
          const lbl  = {beat:'✓ Beat',miss:'✗ Miss',inline:'≈ In-line'}[beat]||'';
          return `<div class="erow">
            <div class="eperiod">${e.period||'—'}</div>
            <div class="eactual ${beat==='beat'?'fgood':beat==='miss'?'fbad':''}">${act!=null?'$'+act.toFixed(2):'—'}</div>
            <div class="eest">Est: ${est!=null?'$'+est.toFixed(2):'—'}</div>
            ${lbl?`<span class="ebdg ${beat}">${lbl}</span>`:''}
          </div>`;
        }).join('')}
      </div></div>`;
  }
  box.innerHTML = `${bn}
    <div class="fsec"><div class="fstitle">Valuation</div><div class="fgrid">${cds(val)}</div></div>
    ${!isETF ? `
    <div class="fsec"><div class="fstitle">Profitability</div><div class="fgrid">${cds(prof)}</div></div>
    <div class="fsec"><div class="fstitle">Growth</div><div class="fgrid">${cds(grw)}</div></div>
    <div class="fsec"><div class="fstitle">Financial Health</div><div class="fgrid">${cds(hlt)}</div></div>
    ${earHtml}` : ''}
    <div style="font-size:11px;color:var(--text-dim);margin-top:6px">Via Finnhub · TTM = Trailing 12 Months · Refreshes every 30 min</div>`;
}

// ═══════════════════════════════════════════════════════════════
// TAB SWITCHING
// ═══════════════════════════════════════════════════════════════
function switchTab(name,btn){
  document.querySelectorAll('[id^="co-tab-"]').forEach(el=>el.style.display='none');
  document.querySelectorAll('.co-tab').forEach(b=>b.classList.remove('active'));
  const el=document.getElementById('co-tab-'+name);
  if(el){ el.style.display='block'; }
  if(btn) btn.classList.add('active');
  if(name==='overview'&&currentTicker){
    const ab=document.querySelector('.period-btn.active');
    loadChart(currentTicker,ab?.textContent||'1M',ab);
  }
  if(name==='fundamentals'&&currentTicker){ loadFundamentals(currentTicker); }
  if(name==='news'&&currentTicker){
    loadNews(currentTicker);
  }
  if(name==='expert'&&currentTicker){
    const q=allQuotes[currentTicker];
    const info=UNIVERSE.find(s=>s.ticker===currentTicker)||{name:currentTicker,sector:'—',industry:'—'};
    if(q) fetchAIAnalysis(currentTicker,q.data,info);
  }
}

// ═══════════════════════════════════════════════════════════════
// SEARCH
// ═══════════════════════════════════════════════════════════════
function setupSearch(){
  const inp=document.getElementById('searchInput');
  const res=document.getElementById('searchResults');
  inp.addEventListener('input',()=>{
    const q=inp.value.toLowerCase().trim();
    if(!q){res.classList.remove('open');return;}
    const found=UNIVERSE.filter(s=>s.ticker.toLowerCase().includes(q)||s.name.toLowerCase().includes(q)).slice(0,7);
    if(!found.length){res.classList.remove('open');return;}
    res.innerHTML=found.map(s=>`<div class="search-item" onclick="searchPick('${s.ticker}')">
      <div class="s-tick">${s.ticker}</div><div class="s-name">${s.name}</div><div class="s-sect">${s.sector}</div>
    </div>`).join('');
    res.classList.add('open');
  });
  document.addEventListener('click',e=>{if(!e.target.closest('.nav-search'))res.classList.remove('open');});
}
function searchPick(t){
  document.getElementById('searchInput').value='';
  document.getElementById('searchResults').classList.remove('open');
  showCompany(t);
}

// ═══════════════════════════════════════════════════════════════
// PAGE NAV / WL / MODE / BANNER
// ═══════════════════════════════════════════════════════════════
function showPage(name){
  document.querySelectorAll('.app').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(el=>el.classList.remove('active'));
  document.getElementById('page-'+name)?.classList.add('active');
  document.getElementById('tab-'+name)?.classList.add('active');
  if(name==='watchlist') renderWatchlist();
}
function toggleWL(ticker){
  watchlist=watchlist.includes(ticker)?watchlist.filter(t=>t!==ticker):[...watchlist,ticker];
  localStorage.setItem('clarity_wl',JSON.stringify(watchlist));
  const btn=document.getElementById('wlBtn');
  if(btn){const in2=watchlist.includes(ticker);btn.textContent=in2?'★ Watchlisted':'☆ Watchlist';btn.classList.toggle('in',in2);}
}
function renderWatchlist(){
  const el=document.getElementById('watchlistGrid'); if(!el) return;
  if(!watchlist.length){
    el.innerHTML=`<div class="wl-empty"><div style="font-size:36px;margin-bottom:12px">☆</div><p>No stocks saved yet.<br>Open any stock page and click <strong>Watchlist</strong>.</p></div>`;
    return;
  }
  el.innerHTML=watchlist.map(ticker=>{
    const info=UNIVERSE.find(s=>s.ticker===ticker);
    const q=allQuotes[ticker]?.data;
    const price=q?.price??'—'; const change=q?.change??0; const up=change>=0;
    return`<div class="wl-item">
      <div class="wl-icon">${ticker.slice(0,3).replace('-','')}</div>
      <div class="wl-info" onclick="showCompany('${ticker}')">
        <div class="wl-name">${info?.name||ticker}</div>
        <div class="wl-tick">${ticker} · ${info?.sector||''}</div>
      </div>
      <div onclick="showCompany('${ticker}')" style="cursor:pointer">
        <div class="wl-price-val">$${typeof price==='number'?fmtPrice(price):price}</div>
        <div style="font-size:11px;text-align:right" class="${up?'up':'dn'}">${change>=0?'+':''}${change.toFixed(2)}%</div>
      </div>
      <div class="wl-remove" onclick="removeWL('${ticker}')" title="Remove">✕</div>
    </div>`;
  }).join('');
}
function removeWL(ticker){
  watchlist=watchlist.filter(t=>t!==ticker);
  localStorage.setItem('clarity_wl',JSON.stringify(watchlist));
  renderWatchlist();
}
function setMode(mode){
  currentMode=mode;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('mode-'+mode).classList.add('active');
  if(currentTicker&&document.getElementById('page-company').classList.contains('active')) showCompany(currentTicker);
}
function showBanner(type,msg){
  const b=document.getElementById('dataBanner');
  b.className=type; b.style.display='flex';
  document.getElementById('bannerMsg').textContent=msg;
  if(type==='live') setTimeout(()=>b.style.display='none',6000);
}

// ═══════════════════════════════════════════════════════════════
// START
// ═══════════════════════════════════════════════════════════════
init();
</script>
</body>
</html>
