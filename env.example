// ═══════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════
let currentMode     = 'beginner';
let currentTicker   = null;
let watchlist       = JSON.parse(localStorage.getItem('clarity_wl') || '[]');
let finnhubKey      = localStorage.getItem('clarity_finnhub_key') || '';
let allQuotes       = {};
const QUOTE_CACHE   = {};
const CHART_CACHE   = {};
const NEWS_CACHE    = {};
const NEWS_TTL      = 10 * 60 * 1000;  // 10 min
const QUOTE_TTL     =  5 * 60 * 1000;  // 5 min

// ═══════════════════════════════════════════════════════════════
// API KEY MODAL
// ═══════════════════════════════════════════════════════════════
function openModal() {
  document.getElementById('finnhubKeyInput').value = finnhubKey;
  updateKeyStatus();
  document.getElementById('setupModal').classList.add('open');
}
function closeModal() {
  document.getElementById('setupModal').classList.remove('open');
}
function saveKey() { saveApiKey(); }
function saveApiKey() {
  const val = document.getElementById('finnhubKeyInput').value.trim();
  if (val) {
    finnhubKey = val;
    localStorage.setItem('clarity_finnhub_key', val);
    updateKeyStatus();
    showBanner('live', '✅ Finnhub API key saved — live news enabled!');
    closeModal();
    // Reload news if on a company page
    if (currentTicker && document.getElementById('co-tab-news')?.style.display !== 'none') {
      loadNews(currentTicker, true);
    }
  } else {
    alert('Please enter a valid API key.');
  }
}
function updateKeyStatus() {
  const el = document.getElementById('keyStatusMsg');
  if (finnhubKey) {
    el.className = 'key-status ok';
    el.textContent = '✓ Key saved — news is live';
  } else {
    el.className = 'key-status missing';
    el.textContent = '⚠ No key saved — news will show sample headlines';
  }
}

// ═══════════════════════════════════════════════════════════════
// CORS PROXY + YAHOO FINANCE
// ═══════════════════════════════════════════════════════════════
const PROXIES = [
  u => `https://corsproxy.io/?${encodeURIComponent(u)}`,
  u => `https://api.allorigins.win/raw?url=${encodeURIComponent(u)}`,
];


// ─── fetch with timeout so CORS proxies never hang ───────────────────────
async function fetchWithTimeout(url, ms=5000) {
  const ctrl = new AbortController();
  const id = setTimeout(() => ctrl.abort(), ms);
  try {
    const r = await fetch(url, { signal: ctrl.signal, headers: {'Accept':'application/json'} });
    clearTimeout(id); return r;
  } catch(e) { clearTimeout(id); throw e; }
}

async function fetchYahoo(ticker, range, interval) {
  range    = range    || '1d';
  interval = interval || '1d';
  try {
    const r = await fetchWithTimeout(
      `/api/quote?ticker=${encodeURIComponent(ticker)}&range=${range}&interval=${interval}`,
      8000
    );
    if (!r.ok) return null;
    const j   = await r.json();
    return j?.chart?.result?.[0] || null;
  } catch(_) { return null; }
}

async function getLiveQuote(ticker) {
  const c = QUOTE_CACHE[ticker];
  if (c && Date.now() - c.ts < QUOTE_TTL) return c;
  const res = await fetchYahoo(ticker);
  if (!res) {
    const fb = FALLBACK[ticker];
    return fb ? { data: fb, ts: 0, source: 'fallback' } : null;
  }
  const m   = res.meta;
  const p   = m.regularMarketPrice ?? m.chartPreviousClose ?? 0;
  const prv = m.previousClose ?? p;
  const da  = p - prv;
  const d   = {
    price:    parseFloat(p.toFixed(2)),
    change:   parseFloat(prv ? ((da/prv)*100).toFixed(2) : '0'),
    changeAmt:parseFloat(da.toFixed(2)),
    open:     m.regularMarketOpen?.toFixed(2)    ?? '—',
    high:     m.regularMarketDayHigh?.toFixed(2) ?? '—',
    low:      m.regularMarketDayLow?.toFixed(2)  ?? '—',
    vol:      fmtVol(m.regularMarketVolume),
    cap:      fmtCap(m.marketCap),
    pe:       m.trailingPE ? parseFloat(m.trailingPE.toFixed(1)) : (FALLBACK[ticker]?.pe ?? '—'),
    eps:      FALLBACK[ticker]?.eps ?? '—',
    wkHigh:   m.fiftyTwoWeekHigh?.toFixed(2)     ?? '—',
    wkLow:    m.fiftyTwoWeekLow?.toFixed(2)      ?? '—',
    div:      FALLBACK[ticker]?.div ?? '—',
    beta:     FALLBACK[ticker]?.beta ?? '—',
  };
  const entry = { data:d, ts:Date.now(), source:'live' };
  QUOTE_CACHE[ticker] = entry;
  return entry;
}

async function getChartData(ticker, range) {
  const key = ticker + range;
  if (CHART_CACHE[key]) return CHART_CACHE[key];
  const ranges    = { '1M':'1mo','6M':'6mo','1Y':'1y','MAX':'max' };
  const intervals = { '1M':'1d', '6M':'1d', '1Y':'1wk','MAX':'1mo' };
  const res = await fetchYahoo(ticker, ranges[range], intervals[range]);
  if (!res) return null;
  const ts  = res.timestamp ?? [];
  const cl  = res.indicators?.quote?.[0]?.close ?? [];
  const pairs = ts.map((t,i) => ({t,v:cl[i]})).filter(p => p.v != null);
  if (pairs.length) CHART_CACHE[key] = pairs;
  return pairs.length ? pairs : null;
}

function fmtVol(n){if(!n)return'—';if(n>=1e9)return(n/1e9).toFixed(1)+'B';if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(0)+'K';return String(n)}
function fmtCap(n){if(!n)return'—';if(n>=1e12)return(n/1e12).toFixed(2)+'T';if(n>=1e9)return(n/1e9).toFixed(0)+'B';return(n/1e6).toFixed(0)+'M'}
function fmtPrice(n){return typeof n==='number'?n.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}):n}
function chunk(arr,s){const o=[];for(let i=0;i<arr.length;i+=s)o.push(arr.slice(i,i+s));return o}

// ═══════════════════════════════════════════════════════════════
// FINNHUB NEWS  (real)
// ═══════════════════════════════════════════════════════════════
async function fetchFinnhubNews(ticker) {
  if (!finnhubKey) return null;
  const cached = NEWS_CACHE[ticker];
  if (cached && Date.now() - cached.ts < NEWS_TTL) return cached.articles;

  // Date range: last 7 days
  const to   = new Date();
  const from = new Date(to - 7 * 86400000);
  const fmt  = d => d.toISOString().split('T')[0];

  // Finnhub company-news endpoint supports CORS natively
  try {
    const url = `/api/finnhub?type=news&ticker=${ticker}&from=${fmt(from)}&to=${fmt(to)}`;
    const r   = await fetch(url);
    if (!r.ok) return null;
    const arr = await r.json();
    if (!Array.isArray(arr)) return null;
    const articles = arr.slice(0, 20).map(a => ({
      source:    a.source || 'News',
      headline:  a.headline,
      summary:   a.summary || '',
      url:       a.url,
      time:      a.datetime,
      image:     a.image || '',
      sentiment: 'neu', // will be scored by AI if available
    }));
    NEWS_CACHE[ticker] = { articles, ts: Date.now() };
    return articles;
  } catch(_) { return null; }
}

// ═══════════════════════════════════════════════════════════════
// AI SENTIMENT SCORING  (batch via Claude)
// ═══════════════════════════════════════════════════════════════
async function scoreSentiment(articles) {
  if (!articles.length) return articles;
  const headlines = articles.map((a,i) => `${i+1}. ${a.headline}`).join('\n');
  try {
    const r = await fetch('/api/claude', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:500,
        messages:[{ role:'user', content:
          `For each headline below, classify the sentiment for a stock investor as: positive, negative, or neutral.
Reply ONLY with a JSON array of strings matching the order, e.g. ["positive","neutral","negative"].
Headlines:\n${headlines}`
        }]
      })
    });
    const data = await r.json();
    const raw  = data.content?.map(c=>c.text||'').join('').replace(/```json|```/g,'').trim();
    const arr  = JSON.parse(raw);
    if (Array.isArray(arr)) {
      return articles.map((a,i) => ({
        ...a,
        sentiment: arr[i]==='positive' ? 'pos' : arr[i]==='negative' ? 'neg' : 'neu'
      }));
    }
  } catch(_) {}
  return articles;
}

// ═══════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════
async function init() {
  setupSearch();
  renderMarketBarSkeletons();
  renderSectorSkeletons();
  // Immediately fill all cards with fallback so page is usable at once
  UNIVERSE.forEach(s => {
    if (FALLBACK[s.ticker]) allQuotes[s.ticker] = { data: FALLBACK[s.ticker], ts: 0, source: 'fallback' };
  });
  renderSectors();
  renderMarketBar();
  showBanner('warn', '⏳ Fetching live prices…');

  const featured = ['AAPL','MSFT','NVDA','AMZN','GOOGL','META','TSLA','JPM','LLY','VOO','QQQ'];
  const results  = await Promise.allSettled(featured.map(t => getLiveQuote(t)));
  let anyLive = false;
  results.forEach((r,i) => {
    if (r.status==='fulfilled' && r.value) {
      allQuotes[featured[i]] = r.value;
      if (r.value.source==='live') anyLive = true;
    }
  });
  anyLive ? showBanner('live','🟢 Live prices (15-min delay) · News powered by Finnhub') : showBanner('warn','⚠ Showing last known prices — live feed unavailable');
  // update market bar with live data for featured
  renderMarketBar();

  const rest = UNIVERSE.map(s=>s.ticker).filter(t=>!featured.includes(t));
  for (const ch of chunk(rest, 5)) {
    const rs = await Promise.allSettled(ch.map(t=>getLiveQuote(t)));
    rs.forEach((r,i)=>{ if(r.status==='fulfilled'&&r.value) allQuotes[ch[i]]=r.value; });
    renderSectors();
  }
}

