<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clarity — Stock Analysis</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0d0f14; --surface:#13161d; --card:#191d27; --border:#232735;
    --border-soft:#1e2230; --text:#e8eaf0; --text-muted:#6b7280; --text-dim:#3d4357;
    --accent:#4f8ef7; --accent-glow:rgba(79,142,247,0.15);
    --green:#34d399; --green-bg:rgba(52,211,153,0.08);
    --red:#f87171;   --red-bg:rgba(248,113,113,0.08);
    --gold:#fbbf24;  --purple:#a78bfa; --radius:12px; --radius-sm:8px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.6;min-height:100vh}

  /* ── NAV ── */
  nav{position:sticky;top:0;z-index:100;background:rgba(13,15,20,0.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 24px;display:flex;align-items:center;gap:20px;height:56px}
  .nav-brand{font-family:'DM Serif Display',serif;font-size:20px;color:var(--text);letter-spacing:-.5px;display:flex;align-items:center;gap:8px;text-decoration:none;cursor:pointer}
  .nav-brand span{color:var(--accent)}
  .nav-search{flex:1;max-width:360px;position:relative}
  .nav-search input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 12px 8px 36px;color:var(--text);font-size:13px;font-family:inherit;outline:none;transition:border-color .2s}
  .nav-search input:focus{border-color:var(--accent)}
  .nav-search input::placeholder{color:var(--text-muted)}
  .search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:15px;pointer-events:none}
  .search-results{position:absolute;top:calc(100% + 6px);left:0;right:0;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;display:none;z-index:200;box-shadow:0 16px 48px rgba(0,0,0,.5)}
  .search-results.open{display:block}
  .search-item{padding:10px 14px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:background .1s}
  .search-item:hover{background:var(--border-soft)}
  .s-tick{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent);min-width:52px}
  .s-name{color:var(--text);font-size:13px}
  .s-sect{color:var(--text-muted);font-size:11px;margin-left:auto}
  .nav-tabs{display:flex;gap:4px;margin-left:auto}
  .nav-tab{padding:6px 14px;border-radius:6px;cursor:pointer;font-size:13px;color:var(--text-muted);transition:all .15s;border:none;background:none;font-family:inherit}
  .nav-tab.active,.nav-tab:hover{background:var(--card);color:var(--text)}
  .nav-tab.active{color:var(--accent)}
  .mode-toggle{display:flex;background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden}
  .mode-btn{padding:5px 12px;cursor:pointer;font-size:12px;font-weight:500;border:none;background:none;color:var(--text-muted);transition:all .15s;font-family:inherit}
  .mode-btn.active{background:var(--accent);color:#fff}

  /* ── API KEY MODAL ── */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(6px);z-index:500;display:none;align-items:center;justify-content:center;padding:24px}
  .modal-overlay.open{display:flex}
  .modal{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:32px;max-width:480px;width:100%;box-shadow:0 24px 80px rgba(0,0,0,.6)}
  .modal h2{font-family:'DM Serif Display',serif;font-size:22px;margin-bottom:8px}
  .modal p{color:var(--text-muted);font-size:13px;line-height:1.65;margin-bottom:20px}
  .modal-field{margin-bottom:16px}
  .modal-label{font-size:12px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;display:block}
  .modal-input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 14px;color:var(--text);font-size:13px;font-family:'JetBrains Mono',monospace;outline:none;transition:border-color .2s}
  .modal-input:focus{border-color:var(--accent)}
  .modal-input::placeholder{color:var(--text-dim);font-family:'DM Sans',sans-serif}
  .modal-actions{display:flex;gap:10px;margin-top:22px}
  .btn-primary{flex:1;padding:10px 18px;border-radius:8px;background:var(--accent);color:#fff;border:none;cursor:pointer;font-size:14px;font-weight:600;font-family:inherit;transition:opacity .15s}
  .btn-primary:hover{opacity:.9}
  .btn-secondary{padding:10px 18px;border-radius:8px;background:none;color:var(--text-muted);border:1px solid var(--border);cursor:pointer;font-size:14px;font-family:inherit;transition:all .15s}
  .btn-secondary:hover{border-color:var(--text-muted);color:var(--text)}
  .api-link{color:var(--accent);text-decoration:none;font-weight:500}
  .api-link:hover{text-decoration:underline}
  .key-status{display:flex;align-items:center;gap:6px;font-size:12px;padding:8px 12px;border-radius:6px;margin-top:10px}
  .key-status.ok{background:var(--green-bg);color:var(--green)}
  .key-status.missing{background:rgba(107,114,128,.08);color:var(--text-muted)}

  /* ── BANNER ── */
  #dataBanner{display:none;align-items:center;gap:10px;padding:7px 24px;font-size:12px;border-bottom:1px solid var(--border-soft)}
  #dataBanner.live{background:rgba(52,211,153,.05);border-bottom-color:rgba(52,211,153,.2);color:var(--green)}
  #dataBanner.warn{background:rgba(251,191,36,.05);border-bottom-color:rgba(251,191,36,.2);color:var(--gold)}
  #dataBanner.err{background:rgba(248,113,113,.05);border-bottom-color:rgba(248,113,113,.2);color:var(--red)}
  .pulse-dot{width:7px;height:7px;border-radius:50%;background:currentColor;animation:blink 2s ease-in-out infinite;flex-shrink:0}
  @keyframes blink{0%,100%{opacity:.3}50%{opacity:1}}

  /* ── PAGES ── */
  .app{display:none}.app.active{display:block}
  .fade-in{animation:fadeIn .25s ease}
  @keyframes fadeIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}

  /* ── HOME ── */
  .home-hero{padding:40px 24px 24px;max-width:1100px;margin:0 auto}
  .hero-title{font-family:'DM Serif Display',serif;font-size:38px;line-height:1.15;margin-bottom:10px}
  .hero-title em{color:var(--accent);font-style:italic}
  .hero-sub{color:var(--text-muted);font-size:15px;max-width:480px}
  .market-bar{max-width:1100px;margin:0 auto 28px;padding:0 24px;display:flex;gap:10px;overflow-x:auto;scrollbar-width:none}
  .market-bar::-webkit-scrollbar{display:none}
  .mbar-item{flex-shrink:0;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 15px;min-width:115px;cursor:pointer;transition:border-color .2s}
  .mbar-item:hover{border-color:var(--accent)}
  .mbar-tick{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);margin-bottom:2px}
  .mbar-price{font-size:15px;font-weight:600}
  .mbar-chg{font-size:11px;margin-top:2px}
  .up{color:var(--green)}.dn{color:var(--red)}
  .section-wrap{max-width:1100px;margin:0 auto;padding:0 24px 48px}
  .section-title{font-size:12px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;display:flex;align-items:center;gap:8px}
  .section-title::after{content:'';flex:1;height:1px;background:var(--border)}
  .stock-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:9px}
  .stock-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:15px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
  .stock-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,0,0,.3)}
  .stock-card::before{content:'';position:absolute;inset:0;opacity:0;background:var(--accent-glow);transition:opacity .2s}
  .stock-card:hover::before{opacity:1}
  .sc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
  .sc-tick{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:500;color:var(--accent)}
  .sc-chg{font-size:11px;padding:2px 6px;border-radius:4px}
  .sc-chg.up{background:var(--green-bg);color:var(--green)}.sc-chg.dn{background:var(--red-bg);color:var(--red)}
  .sc-name{font-size:12px;color:var(--text-muted);margin-bottom:7px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .sc-price{font-size:19px;font-weight:600}
  .sc-bar{height:2px;background:var(--border);border-radius:1px;margin-top:11px;overflow:hidden}
  .sc-bar-fill{height:100%;border-radius:1px;background:linear-gradient(90deg,var(--accent),var(--purple))}
  .skeleton{background:linear-gradient(90deg,var(--border) 25%,var(--surface) 50%,var(--border) 75%);background-size:200% 100%;animation:skel 1.5s infinite;border-radius:4px}
  @keyframes skel{0%{background-position:200% 0}100%{background-position:-200% 0}}

  /* ── COMPANY PAGE ── */
  .company-wrap{max-width:1100px;margin:0 auto;padding:24px}
  .co-header{display:flex;align-items:flex-start;gap:20px;margin-bottom:22px;padding:22px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius)}
  .co-logo{width:50px;height:50px;border-radius:11px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent);font-weight:700;border:1px solid var(--border);flex-shrink:0}
  .co-info{flex:1}
  .co-name-row{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap}
  .co-name{font-family:'DM Serif Display',serif;font-size:24px;line-height:1.2}
  .co-meta{display:flex;align-items:center;gap:8px;margin-top:5px;flex-wrap:wrap}
  .co-tick{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent)}
  .tag{font-size:11px;color:var(--text-muted);background:var(--surface);padding:2px 8px;border-radius:4px}
  .live-badge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:.5px}
  .live-badge.live{background:rgba(52,211,153,.12);color:var(--green);border:1px solid rgba(52,211,153,.25)}
  .live-badge.cached{background:rgba(251,191,36,.1);color:var(--gold);border:1px solid rgba(251,191,36,.2)}
  .live-badge.fallback{background:rgba(107,114,128,.1);color:var(--text-muted);border:1px solid var(--border)}
  .co-extras{display:flex;gap:16px;margin-top:8px;flex-wrap:wrap}
  .co-extra-item{font-size:11px;color:var(--text-muted)}
  .co-extra-item strong{color:var(--text);font-size:12px}
  .co-price-block{text-align:right;flex-shrink:0}
  .co-price{font-size:30px;font-weight:700}
  .co-chg{font-size:13px;margin-top:2px}
  .co-tabs{display:flex;gap:2px;margin-bottom:18px;background:var(--surface);border-radius:var(--radius-sm);padding:4px;width:fit-content}
  .co-tab{padding:7px 17px;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-muted);transition:all .15s;border:none;background:none;font-family:inherit}
  .co-tab.active{background:var(--card);color:var(--text)}
  .wl-btn{padding:7px 14px;border-radius:7px;cursor:pointer;font-size:12px;font-weight:600;border:1px solid var(--border);background:var(--surface);color:var(--text-muted);transition:all .15s;font-family:inherit}
  .wl-btn:hover,.wl-btn.in{background:var(--accent);border-color:var(--accent);color:#fff}

  /* ── METRICS ── */
  .metrics-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:9px;margin-bottom:18px}
  .metric-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:13px 15px}
  .metric-label{font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px;display:flex;align-items:center}
  .metric-value{font-size:19px;font-weight:600}
  .metric-sub{font-size:11px;color:var(--text-muted);margin-top:2px}
  .metric-explain{font-size:11px;color:var(--text-dim);margin-top:6px;padding-top:6px;border-top:1px solid var(--border);line-height:1.5}
  .tip-wrap{position:relative;display:inline-flex;align-items:center}
  .tip-icon{width:13px;height:13px;border-radius:50%;background:var(--border);color:var(--text-muted);font-size:9px;display:inline-flex;align-items:center;justify-content:center;cursor:help;margin-left:5px}
  .tip-box{position:absolute;bottom:calc(100% + 6px);left:0;background:#1e2230;border:1px solid var(--border);border-radius:6px;padding:8px 10px;font-size:11px;color:var(--text-muted);width:180px;line-height:1.5;display:none;z-index:200;pointer-events:none}
  .tip-wrap:hover .tip-box{display:block}

  /* ── CHART ── */
  .chart-area{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:18px}
  .chart-header{display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap}
  .chart-title{font-size:13px;font-weight:600}
  .chart-status{font-size:11px;color:var(--text-muted)}
  .period-btns{display:flex;gap:3px;margin-left:auto}
  .period-btn{padding:4px 10px;border-radius:4px;cursor:pointer;font-size:11px;font-weight:500;color:var(--text-muted);border:1px solid var(--border);background:none;transition:all .15s;font-family:inherit}
  .period-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
  canvas{width:100%;height:220px;display:block}
  .chart-loading{height:220px;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:13px;gap:10px}

  /* ── NEWS ── */
  .news-grid{display:grid;gap:10px}
  .news-toolbar{display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap}
  .news-filter-btn{padding:5px 12px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:500;border:1px solid var(--border);background:none;color:var(--text-muted);transition:all .15s;font-family:inherit}
  .news-filter-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
  .news-count{font-size:12px;color:var(--text-muted);margin-left:auto}
  .news-item{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px 16px;display:flex;gap:14px;cursor:pointer;transition:border-color .2s;text-decoration:none;position:relative}
  .news-item:hover{border-color:var(--accent)}
  .news-item.pos-border{border-left:3px solid var(--green)}
  .news-item.neg-border{border-left:3px solid var(--red)}
  .news-item.neu-border{border-left:3px solid var(--border)}
  .news-body{flex:1;min-width:0}
  .news-meta{display:flex;align-items:center;gap:8px;margin-bottom:5px;flex-wrap:wrap}
  .news-src{font-size:10px;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.5px}
  .news-time{font-size:11px;color:var(--text-dim)}
  .news-head{font-size:13px;font-weight:500;margin-bottom:5px;color:var(--text);line-height:1.45}
  .news-desc{font-size:12px;color:var(--text-muted);line-height:1.5;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
  .news-sent{font-size:11px;padding:3px 9px;border-radius:20px;align-self:flex-start;flex-shrink:0;white-space:nowrap;font-weight:500}
  .news-sent.pos{background:var(--green-bg);color:var(--green)}
  .news-sent.neu{background:rgba(107,114,128,.1);color:var(--text-muted)}
  .news-sent.neg{background:var(--red-bg);color:var(--red)}
  .news-image{width:72px;height:72px;border-radius:8px;object-fit:cover;flex-shrink:0;background:var(--surface);border:1px solid var(--border)}
  .news-setup{background:var(--card);border:1px solid rgba(79,142,247,.2);border-radius:var(--radius);padding:24px;text-align:center}
  .news-setup h3{font-family:'DM Serif Display',serif;font-size:18px;margin-bottom:8px}
  .news-setup p{color:var(--text-muted);font-size:13px;line-height:1.6;margin-bottom:16px}

  /* ── AI BLOCK ── */
  .ai-block{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:18px}
  .ai-header{display:flex;align-items:center;gap:10px;margin-bottom:12px}
  .ai-badge{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:3px 8px;background:var(--accent-glow);color:var(--accent);border:1px solid rgba(79,142,247,.3);border-radius:4px}
  .ai-title{font-size:13px;font-weight:600}
  .ai-text{color:var(--text-muted);font-size:13px;line-height:1.75}
  .dot-pulse{display:flex;gap:4px;align-items:center}
  .dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:dpulse 1.4s ease-in-out infinite}
  .dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
  @keyframes dpulse{0%,80%,100%{opacity:.2;transform:scale(.8)}40%{opacity:1;transform:scale(1)}}

  /* ── COMPARE ── */
  .compare-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:18px}
  .compare-table{width:100%;border-collapse:collapse}
  .compare-table th{background:var(--surface);padding:11px 14px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.8px;border-bottom:1px solid var(--border)}
  .compare-table td{padding:11px 14px;border-bottom:1px solid var(--border-soft);font-size:13px}
  .compare-table tr:last-child td{border-bottom:none}
  .compare-table tr.hl td{background:rgba(79,142,247,.04)}
  .compare-table td:first-child{font-weight:600}
  .mono{font-family:'JetBrains Mono',monospace;font-size:12px}

  /* ── STRENGTH ── */
  .strength-row{display:flex;flex-direction:column;gap:8px;margin-top:12px}
  .strength-item{display:flex;align-items:center;gap:10px;font-size:12px}
  .strength-label{width:88px;color:var(--text-muted);flex-shrink:0}
  .str-bg{flex:1;height:4px;background:var(--border);border-radius:2px;overflow:hidden}
  .str-fill{height:100%;border-radius:2px;transition:width .6s ease}
  .str-score{width:28px;text-align:right;font-family:'JetBrains Mono',monospace;font-size:11px}

  /* ── WATCHLIST ── */
  .watchlist-wrap{max-width:1100px;margin:0 auto;padding:24px}
  .wl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(255px,1fr));gap:11px}
  .wl-item{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;display:flex;gap:13px;align-items:center;transition:border-color .2s}
  .wl-item:hover{border-color:var(--accent)}
  .wl-icon{width:40px;height:40px;border-radius:10px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--accent);font-weight:700;border:1px solid var(--border);flex-shrink:0}
  .wl-info{flex:1;cursor:pointer}
  .wl-name{font-size:13px;font-weight:600}
  .wl-tick{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-muted)}
  .wl-price-val{font-size:15px;font-weight:600;text-align:right;cursor:pointer}
  .wl-remove{color:var(--text-dim);cursor:pointer;padding:4px;transition:color .15s;font-size:16px;flex-shrink:0}
  .wl-remove:hover{color:var(--red)}
  .wl-empty{text-align:center;padding:60px 24px;color:var(--text-muted);grid-column:1/-1}
  .beg-hint{background:rgba(79,142,247,.06);border:1px solid rgba(79,142,247,.15);border-radius:var(--radius-sm);padding:11px 14px;margin-bottom:16px;font-size:12px;color:#9bb4e8;line-height:1.6}
  .beg-hint strong{color:var(--accent)}

  /* ── SETTINGS BTN ── */
  .settings-btn{background:none;border:1px solid var(--border);border-radius:7px;padding:6px 11px;cursor:pointer;color:var(--text-muted);font-size:18px;transition:all .15s;line-height:1}
  .settings-btn:hover{border-color:var(--accent);color:var(--accent)}


  .fsec{margin-bottom:22px}
  .fstitle{font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border)}
  .fgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px}
  .fcard{background:var(--card);border:1px solid var(--border);border-radius:var(--rs);padding:12px 14px}
  .fl{font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.7px;margin-bottom:4px}
  .fv{font-size:17px;font-weight:600}.fsub{font-size:11px;color:var(--text-muted);margin-top:2px}
  .fgood{color:var(--green)}.fbad{color:var(--red)}.fneu{color:var(--text)}
  .erow{display:flex;align-items:center;gap:10px;padding:9px 12px;border-bottom:1px solid var(--border-soft);font-size:12px}
  .erow:last-child{border-bottom:none}.eperiod{width:80px;color:var(--text-muted);flex-shrink:0}
  .eactual{width:70px;font-family:'JetBrains Mono',monospace;font-size:12px}
  .eest{width:70px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-muted)}
  .ebdg{font-size:11px;padding:2px 7px;border-radius:4px;margin-left:auto}
  .ebdg.beat{background:var(--green-bg);color:var(--green)}.ebdg.miss{background:var(--red-bg);color:var(--red)}.ebdg.inline{background:rgba(107,114,128,.1);color:var(--text-muted)}

  ::-webkit-scrollbar{width:5px;height:5px}
  ::-webkit-scrollbar-track{background:transparent}
  ::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
  @media(max-width:700px){.hero-title{font-size:26px}.co-header{flex-wrap:wrap}.co-price-block{width:100%;text-align:left}.metrics-grid{grid-template-columns:1fr 1fr}.mode-btn{padding:5px 8px;font-size:11px}}
</style>
</head>
<body>

<!-- ── API KEY SETUP MODAL ── -->
<div class="modal-overlay" id="setupModal">
  <div class="modal">
    <h2>Connect Your News Feed 📰</h2>
    <p>Clarity uses <strong>Finnhub</strong> for live news and <strong>Claude AI</strong> for analysis. These APIs are configured by the site owner. If you're running your own instance, add your keys as environment variables.</p>

    <div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px;margin-bottom:18px;font-size:12px;color:var(--text-muted);line-height:1.7">
      1. Go to <a href="https://finnhub.io/register" target="_blank" class="api-link">finnhub.io/register</a> — free, no credit card<br>
      2. Copy your API key from the dashboard<br>
      3. Paste it below and click Save
    </div>

    <div class="modal-field">
      <label class="modal-label">Finnhub API Key</label>
      <input class="modal-input" id="finnhubKeyInput" placeholder="e.g. cq1234abcdefgh5678ij" type="text" autocomplete="off">
    </div>

    <div id="keyStatusMsg" class="key-status missing">⚠ No key saved yet — news will show illustrative headlines</div>

    <div class="modal-actions">
      <button class="btn-primary" onclick="saveApiKey()">Save & Load News</button>
      <button class="btn-secondary" onclick="closeModal()">Skip for now</button>
    </div>
  </div>
</div>

<!-- ── NAV ── -->
<nav>
  <div class="nav-brand" onclick="showPage('home')">Clarity<span>.</span></div>
  <div class="nav-search">
    <span class="search-icon">⌕</span>
    <input type="text" id="searchInput" placeholder="Search ticker or company…" autocomplete="off">
    <div class="search-results" id="searchResults"></div>
  </div>
  <div class="nav-tabs">
    <button class="nav-tab active" id="tab-home" onclick="showPage('home')">Market</button>
    <button class="nav-tab" id="tab-watchlist" onclick="showPage('watchlist')">Watchlist</button>
  </div>
  <div class="mode-toggle">
    <button class="mode-btn active" id="mode-beginner" onclick="setMode('beginner')">Beginner</button>
    <button class="mode-btn" id="mode-intermediate" onclick="setMode('intermediate')">Pro</button>
    <button class="mode-btn" id="mode-advanced" onclick="setMode('advanced')">Expert</button>
  </div>
  <button class="settings-btn" onclick="openModal()" title="API settings">⚙</button>
</nav>

<!-- ── DATA BANNER ── -->
<div id="dataBanner">
  <div class="pulse-dot"></div>
  <span id="bannerMsg"></span>
  <span style="margin-left:auto;cursor:pointer;color:var(--text-dim)" onclick="document.getElementById('dataBanner').style.display='none'">✕</span>
</div>

<!-- ── HOME PAGE ── -->
<div class="app active fade-in" id="page-home">
  <div class="home-hero">
    <div class="hero-title">Smart analysis,<br><em>without the noise.</em></div>
    <div class="hero-sub">Curated stocks. Real prices. Real news. Explained at your level.</div>
  </div>
  <div class="market-bar" id="marketBar"></div>
  <div class="section-wrap" id="sectorSections"></div>
</div>

<!-- ── COMPANY PAGE ── -->
<div class="app fade-in" id="page-company">
  <div class="company-wrap" id="companyContent"></div>
</div>

<!-- ── WATCHLIST PAGE ── -->
<div class="app fade-in" id="page-watchlist">
  <div class="watchlist-wrap">
    <div style="margin-bottom:22px">
      <div style="font-family:'DM Serif Display',serif;font-size:26px">Your Watchlist</div>
      <div style="color:var(--text-muted);font-size:13px;margin-top:4px">Companies you're tracking.</div>
    </div>
    <div class="wl-grid" id="watchlistGrid"></div>
  </div>
</div>

