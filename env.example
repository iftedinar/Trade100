          <span class="live-badge ${bc}">${bt}</span>
        </div>
        <div class="co-extras">
          <div class="co-extra-item">Open <strong>$${d.open}</strong></div>
          <div class="co-extra-item">High <strong style="color:var(--green)">$${d.high}</strong></div>
          <div class="co-extra-item">Low <strong style="color:var(--red)">$${d.low}</strong></div>
