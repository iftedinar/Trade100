function renderSectorSkeletons(){
  const secs=[...new Set(UNIVERSE.map(s=>s.sector))];
  document.getElementById('sectorSections').innerHTML=secs.map(sec=>{
    const stocks=UNIVERSE.filter(s=>s.sector===sec);
    return`<div style="margin-bottom:30px">
      <div class="section-title">${sec}</div>
      <div class="stock-grid">${stocks.map(s=>`
        <div class="stock-card" id="sc-${s.ticker}" onclick="showCompany('${s.ticker}')">
          <div class="sc-top"><div class="sc-tick">${s.ticker}</div></div>
          <div class="sc-name">${s.name}</div>
          <div class="skeleton" style="height:19px;width:80px;margin-top:2px"></div>
          <div class="sc-bar"><div class="sc-bar-fill" style="width:0"></div></div>
        </div>`).join('')}
      </div></div>`;
  }).join('');
}
function renderSectors(){
  UNIVERSE.forEach(s=>{
    const el=document.getElementById('sc-'+s.ticker);
    const q=allQuotes[s.ticker]; if(!el||!q) return;
    const {price,change}=q.data; const up=change>=0;
    const bw=Math.min(Math.abs(change)*20,100);
    el.innerHTML=`
      <div class="sc-top"><div class="sc-tick">${s.ticker}</div><div class="sc-chg ${up?'up':'dn'}">${up?'+':''}${change.toFixed(2)}%</div></div>
      <div class="sc-name">${s.name}</div>
      <div class="sc-price">$${fmtPrice(price)}</div>
      <div class="sc-bar"><div class="sc-bar-fill" style="width:${bw}%"></div></div>`;
  });
}

