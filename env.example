          ${d.wkHigh!=='—'?`<div class="co-extra-item">52W <strong>$${d.wkLow}–$${d.wkHigh}</strong></div>`:''}
        </div>
      </div>
      <div class="co-price-block">
        <div class="co-price">$${fmtPrice(d.price)}</div>
        <div class="co-chg ${up?'up':'dn'}">${up?'▲':'▼'} $${Math.abs(d.changeAmt).toFixed(2)} (${Math.abs(d.change).toFixed(2)}%) today</div>
      </div>
    </div>

    <div style="display:flex;gap:10px;margin-bottom:18px;align-items:center;flex-wrap:wrap">
      <div class="co-tabs">
        <button class="co-tab active" onclick="switchTab('overview',this)">Overview</button>
