function renderMarketBarSkeletons(){
  const tks=['AAPL','MSFT','NVDA','AMZN','GOOGL','META','TSLA','JPM','LLY','VOO','QQQ'];
  document.getElementById('marketBar').innerHTML=tks.map(t=>`
    <div class="mbar-item" id="mb-${t}" onclick="showCompany('${t}')">
      <div class="mbar-tick">${t}</div>
      <div class="skeleton" style="height:15px;width:70px;margin:4px 0"></div>
      <div class="skeleton" style="height:11px;width:45px"></div>
    </div>`).join('');
}
function renderMarketBar(){
  ['AAPL','MSFT','NVDA','AMZN','GOOGL','META','TSLA','JPM','LLY','VOO','QQQ'].forEach(t=>{
    const el=document.getElementById('mb-'+t);
    const q=allQuotes[t]; if(!el||!q) return;
    const {price,change}=q.data; const up=change>=0;
    el.innerHTML=`<div class="mbar-tick">${t}</div><div class="mbar-price">$${fmtPrice(price)}</div><div class="mbar-chg ${up?'up':'dn'}">${up?'+':''}${change.toFixed(2)}%</div>`;
  });
}

